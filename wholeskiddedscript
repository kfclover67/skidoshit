local removeShootAnimations = false
local shootAnimationIds = {}

window:addToggle("Remove Shoot Animation", false, function(enabled)
    removeShootAnimations = enabled
    if enabled then
        createNotification("Shoot Animations Removed", 2)
        
        local function stopShootAnimations(char)
            local animator = char:FindFirstChildOfClass("Animator")
            if animator then
                local tracks = animator:GetPlayingAnimationTracks()
                for _, track in ipairs(tracks) do
                    if shootAnimationIds[track.Animation.AnimationId] then
                        track:Stop()
                    end
                end
            end
        end
        
        local function trackNewAnimations(char)
            char.DescendantAdded:Connect(function(desc)
                if desc:IsA("AnimationTrack") and removeShootAnimations then
                    if shootAnimationIds[desc.Animation.AnimationId] then
                        desc:Stop()
                    end
                end
            end)
        end
        
        for _, plr in pairs(game:GetService("Players"):GetPlayers()) do
            local char = plr.Character
            if char then
                stopShootAnimations(char)
                trackNewAnimations(char)
            end
            plr.CharacterAdded:Connect(function(char)
                stopShootAnimations(char)
                trackNewAnimations(char)
            end)
        end
        
        game:GetService("Players").PlayerAdded:Connect(function(plr)
            plr.CharacterAdded:Connect(function(char)
                stopShootAnimations(char)
                trackNewAnimations(char)
            end)
        end)
        
        task.spawn(function()
            while removeShootAnimations do
                for _, plr in pairs(game:GetService("Players"):GetPlayers()) do
                    local char = plr.Character
                    if char then
                        stopShootAnimations(char)
                    end
                end
                runService.RenderStepped:Wait()
            end
        end)
    else
        createNotification("Shoot Animations Restored", 1.5)
    end
end)

