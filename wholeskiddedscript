            local animRun = Instance.new("Animation")
            animRun.AnimationId = "rbxassetid://3541114300"
            
            local animWalk = Instance.new("Animation")
            animWalk.AnimationId = "rbxassetid://3541044388"
            
            while cframeFlyRunning do
                task.wait()
                local moveDir = humanoid.MoveDirection
                if moveDir.Magnitude > 0 then
                    if not animWalk or not animWalk.IsPlaying then
                        if animIdle then
                            animIdle:Stop()
                        end
                        animWalk = animatorInstance:LoadAnimation(animWalk)
                        animWalk:Play()
                    end
                else
                    if not animIdle or not animIdle.IsPlaying then
                        if animWalk then
                            animWalk:Stop()
                        end
                        animIdle = animatorInstance:LoadAnimation(animRun)
                        animIdle:Play()
                    end
                end
            end
            
            if animIdle then
                animIdle:Stop()
            end
            if animWalk then
                animWalk:Stop()
            end
        end)
    else
        createNotification("CFrame Fly Disabled", 1.5)
        cframeFlyRunning = false
        if animIdle then
            animIdle:Stop()
        end
        if animWalk then
