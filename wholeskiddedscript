window:addToggle(Enum.KeyCode.E, function(enabled)
    killAura.enabled = enabled
    killAura.active = enabled
    
    if enabled then
        createNotification("Kill Aura Activated", 2)
        task.spawn(function()
            while killAura.enabled do
                local localPlayer = game:GetService("Players").LocalPlayer
                local char = localPlayer.Character
                local rootPart = char and char:FindFirstChild("HumanoidRootPart")
                
                if rootPart then
                    local target = nil
                    local playersList = game:GetService("Players"):GetPlayers()
                    
                    for _, plr in pairs(playersList) do
                        if plr ~= localPlayer and not killAura.whitelist[plr.Name] then
                            local plrChar = plr.Character
                            if plrChar and plrChar:FindFirstChild("Head") then
                                local distance = (rootPart.Position - plrChar.Head.Position).Magnitude
                                if distance <= killAura.range then
                                    target = plr
                                end
                            end
                        end
                    end
                    
                    if target then
                        local tools = char:GetChildren()
                        for _, tool in ipairs(tools) do
                            if tool:IsA("Tool") and tool:FindFirstChild("Handle") and tool:FindFirstChild("Ammo") then
                                local mainEvent = game:GetService("ReplicatedStorage"):FindFirstChild("MainEvent")
                                if mainEvent then
                                    mainEvent:FireServer("ShootGun", tool.Handle, tool.Handle.CFrame.Position, target.Character.Head.Position, target.Character.Head, Vector3.new(0, 0, -1))
                                end
                            end
                        end
                    end
                end
                task.wait()
            end
        end)
    else
        createNotification("Kill Aura Disabled", 1.5)
        killAura.active = false
        if killAura.tracer then
            killAura.tracer.Transparency = 1
        end
    end
end)

