local function getCharacter()
    return player.Character
end

local function equipTool(toolName)
    local char = getCharacter()
    local backpack = player.Backpack
    local tool = backpack:FindFirstChild(toolName)
    if tool then
        local char = getCharacter()
        tool.Parent = char
        task.wait(0.1)
        local humanoid = char:FindFirstChildOfClass("Humanoid")
        if humanoid then
            humanoid:EquipTool(tool)
            char.HumanoidRootPart.CFrame = CFrame.new(-117, -57, 147)
        end
    end
end

local function activateTool(toolName)
    local char = getCharacter()
    local tool = char:FindFirstChild(toolName)
    if tool then
        tool:Activate()
    end
end

local function teleportToItem(item, target)
    local char = getCharacter()
    local targetCFrame = target.Head.CFrame * CFrame.new(0, 2, 3)
    char.HumanoidRootPart.CFrame = targetCFrame
    task.wait(0.25)
    if target:FindFirstChild("ClickDetector") then
        fireclickdetector(target.ClickDetector)
    end
    task.wait(0.25)
end

local function farmItem(item, target)
    task.spawn(function()
        while false do
            local char = getCharacter()
            if not char then
                break
            else
                local tool = char:FindFirstChild(item)
                if tool then
                    activateTool(item)
                else
                    local backpack = player.Backpack
                    local toolInBackpack = backpack:FindFirstChild(item)
                    if not toolInBackpack then
                        teleportToItem(item, target)
                        task.wait(0.25)
                    end
                    equipTool(item)
                    task.wait(0.1)
                end
            end
        end
    end)
end

