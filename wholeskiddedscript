local function createNotification(text, duration, userId)
    duration = duration or 3
    
    local frame = Instance.new("Frame")
    local corner = Instance.new("UICorner")
    local label = Instance.new("TextLabel")
    local avatar = Instance.new("ImageLabel")
    
    frame.Name = "NotificationLog"
    frame.Parent = notificationGui
    frame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    frame.BorderSizePixel = 0
    frame.ClipsDescendants = true
    frame.AnchorPoint = Vector2.new(0, 0.5)
    frame.Size = UDim2.new(0, 0, 0, 35)
    frame.Position = UDim2.new(0, 25, 0.5, 0)
    
    corner.CornerRadius = UDim.new(0, 8)
    corner.Parent = frame
    
    if userId then
        avatar.Name = "Avatar"
        avatar.Parent = frame
        avatar.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
        avatar.BorderSizePixel = 0
        avatar.Position = UDim2.new(0, 5, 0, 2)
        avatar.Size = UDim2.new(0, 31, 0, 31)
        avatar.Image = "rbxthumb://type=AvatarHeadShot&id=" .. userId .. "&w=420&h=420"
        avatar.ImageTransparency = 0
        
        local avatarCorner = Instance.new("UICorner")
        avatarCorner.CornerRadius = UDim.new(0, 8)
        avatarCorner.Parent = avatar
        
        label.Position = UDim2.new(0, 42, 0, 0)
        label.Size = UDim2.new(1, -47, 1, 0)
    else
        label.Position = UDim2.new(0, 12, 0, 0)
        label.Size = UDim2.new(1, -17, 1, 0)
    end
    
    label.Name = "Label"
    label.Parent = frame
    label.BackgroundTransparency = 1
    label.Font = Enum.Font.GothamSemibold
    label.Text = text
    label.TextColor3 = Color3.fromRGB(255, 255, 255)
    label.TextSize = 11
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.TextTransparency = 1
    
    for i = #notifications, 1, -1 do
        local notif = notifications[i]
        notif.TargetY = notif.TargetY - (35 + 8)
        if #notifications - i >= 2 then
            task.spawn(function()
                notif.Frame:TweenSize(UDim2.new(0, 0, 0, 35), "In", "Quad", 0.2, true)
                task.wait(0.2)
                notif.Frame:Destroy()
            end)
            table.remove(notifications, i)
        else
            notif.Frame:TweenPosition(UDim2.new(0, 25, 0.5, notif.TargetY), "Out", "Quad", 0.3, true)
        end
    end
    
    table.insert(notifications, {Frame = frame, TargetY = 0})
    frame:TweenSize(UDim2.new(0, 220, 0, 35), "Out", "Quad", 0.3, true)
    
    task.spawn(function()
        task.wait(0.15)
        for i = 1, 0, -0.05 do
            label.TextTransparency = i
            task.wait(0.02)
        end
        label.TextTransparency = 0
    end)
    
    task.spawn(function()
        task.wait(duration)
        for i, notif in ipairs(notifications) do
            if notif.Frame == frame then
                table.remove(notifications, i)
            end
        end
        if frame and frame.Parent then
            frame:TweenSize(UDim2.new(0, 0, 0, 35), "In", "Quad", 0.2, true)
            task.wait(0.2)
            frame:Destroy()
        end
    end)
end

local function setupDamageTracker(char)
    local bodyEffects = char:WaitForChild("BodyEffects", 12)
    if bodyEffects then
        local lastDamager = bodyEffects:WaitForChild("LastDamager", 12)
        if lastDamager then
            lastDamager:GetPropertyChangedSignal("Value"):Connect(function()
                local damager = lastDamager.Value
                if damager then
                    local plr = getPlayerFromCharacter(damager)
                    if plr then
                        createNotification("Hit by " .. plr.Name, 4, plr.UserId)
                    end
                end
            end)
        end
    end
end

