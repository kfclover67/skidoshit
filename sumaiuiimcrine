            ToggleHolder.BackgroundColor3 = Color3.fromRGB(17,17,17)
            ToggleBall:TweenPosition(UDim2.new(0.123, 0,0.158, 0),"Out","Linear",0.1)
        end
        
        UpdateScreenButtonVisuals()
        pcall(callback, ToggleEnabled)
    end

    -- Normal UI Click
    ToggleButton.MouseButton1Down:Connect(FireToggle)

    if isMobile then
        -- Mobile Handling: Toggle floating shortcut button existence
        BindButton.MouseButton1Down:Connect(function()
            if screenButton then
                screenButton:Destroy()
                screenButton = nil
                BindButton.Text = "Show"
                BindButton.TextColor3 = Color3.fromRGB(150, 150, 150)
            else
                BindButton.Text = "Hide"
                BindButton.TextColor3 = Color3.fromRGB(255, 255, 255)
                
                screenButton = Instance.new("TextButton")
                local screenCorner = Instance.new("UICorner")
                
                screenButton.Name = (togglename or "Toggle") .. "_Shortcut"
                screenButton.Parent = shared.SkidoMobileGui
                screenButton.Size = UDim2.new(0, 75, 0, 28)
                
                -- Calculate row allocation heights on the right flank to block absolute stacking overlays
                local initialYOffset = (shared.SkidoMobileOffsetCount % 10) * 33
                screenButton.Position = UDim2.new(1, -90, 0.35, initialYOffset)
                shared.SkidoMobileOffsetCount = shared.SkidoMobileOffsetCount + 1
                
                screenButton.Font = Enum.Font.GothamBold
                screenButton.Text = togglename or "Toggle"
                screenButton.TextSize = 9.000
                screenButton.TextWrapped = true
                
                screenCorner.CornerRadius = UDim.new(0, 5)
                screenCorner.Parent = screenButton
                
                UpdateScreenButtonVisuals()
                
                -- Fast Click Execution Connection
                screenButton.MouseButton1Down:Connect(FireToggle)
                
                -- Fully Responsive Mobile Touch Drag Mechanics
                local dragging = false
                local dragInput = nil
                local dragStart = nil
                local startPos = nil
                
                screenButton.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
                        dragging = true
                        dragStart = input.Position
                        startPos = screenButton.Position
                        
                        input.Changed:Connect(function()
                            if input.UserInputState == Enum.UserInputState.End then
                                dragging = false
                            end
                        end)
                    end
                end)
                
                screenButton.InputChanged:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseMovement then
                        dragInput = input
                    end
                end)
                
                UserInputService.InputChanged:Connect(function(input)
                    if input == dragInput and dragging then
                        local delta = input.Position - dragStart
                        screenButton.Position = UDim2.new(
                            startPos.X.Scale, 
                            startPos.X.Offset + delta.X, 
                            startPos.Y.Scale, 
                            startPos.Y.Offset + delta.Y
                        )
                    end
                end)
            end
        end)
    else
        -- PC Keyboard Input Keybind Mapping
        BindButton.MouseButton1Down:Connect(function()
            isListening = true
            BindButton.Text = "..."
            BindButton.TextColor3 = Color3.fromRGB(255, 255, 255)
        end)

        UserInputService.InputBegan:Connect(function(input, gameProcessedEvent)
            if isListening then
                if input.UserInputType == Enum.UserInputType.Keyboard then
                    if input.KeyCode == Enum.KeyCode.Escape or input.KeyCode == Enum.KeyCode.Backspace then
                        currentBind = nil
                        BindButton.Text = "None"
                    else
                        currentBind = input.KeyCode
                        BindButton.Text = currentBind.Name
                    end
                    BindButton.TextColor3 = Color3.fromRGB(150, 150, 150)
                    isListening = false
                end
            else
                if not gameProcessedEvent and currentBind and input.KeyCode == currentBind and BindButton.Visible then
                    FireToggle()
                end
            end
        end)
    end
end
