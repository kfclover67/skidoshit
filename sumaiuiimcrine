    SliderNumber.TextColor3 = Color3.fromRGB(255, 255, 255)
    SliderNumber.TextSize = 10.000
    SliderNumber.TextXAlignment = Enum.TextXAlignment.Right -- Aligns cleanly against the boundary box
    SliderNumber.ClearTextOnFocus = false                    -- Keeps current value visible when you click it
    SliderNumber.TextEditable = true

    local mouse = game.Players.LocalPlayer:GetMouse()
    local uis = game:GetService("UserInputService")
    local Value;

    -- Handle Dragging Math Interaction
    SliderButton.MouseButton1Down:Connect(function()
        Value = math.floor((((max - min) / 273) * SliderTrail.AbsoluteSize.X) + min) or 0
        callback(SliderNumber.Text)
        SliderTrail.Size = UDim2.new(0, math.clamp(mouse.X - SliderButton.AbsolutePosition.X, 0, 273), 0, 7)
        
        moveconnection = mouse.Move:Connect(function()
            SliderNumber.Text = tostring(Value)
            Value = math.floor((((max - min) / 273) * SliderTrail.AbsoluteSize.X) + min)
            callback(SliderNumber.Text)
            SliderHolder.BackgroundColor3 = Color3.fromRGB(14,14,14)
            SliderTrail.Size = UDim2.new(0, math.clamp(mouse.X - SliderButton.AbsolutePosition.X, 0, 273), 0, 7)
        end)
        
        releaseconnection = uis.InputEnded:Connect(function(Mouse)
            if Mouse.UserInputType == Enum.UserInputType.MouseButton1 then
                Value = math.floor((((max - min) / 273) * SliderTrail.AbsoluteSize.X) + min)
                callback(SliderNumber.Text)
                SliderHolder.BackgroundColor3 = Color3.fromRGB(17,17,17)
                SliderTrail.Size = UDim2.new(0, math.clamp(mouse.X - SliderButton.AbsolutePosition.X, 0, 273), 0, 7)
                moveconnection:Disconnect()
                releaseconnection:Disconnect()
            end
        end)
    end)

    -- NEW: Handle Manual Text Input Custom Entry Logic
    SliderNumber.FocusLost:Connect(function(enterPressed)
        local inputVal = tonumber(SliderNumber.Text)
        
        -- If input is empty or contains non-numeric strings, revert back to the bar's current location value
        if not inputVal then
            inputVal = math.floor((((max - min) / 273) * SliderTrail.AbsoluteSize.X) + min)
        end
        
        -- Automatically lock boundaries between min and max parameters
        inputVal = math.clamp(inputVal, min, max)
        
        -- Update input visually inside the text boundary box
        SliderNumber.Text = tostring(inputVal)
        
        -- Map values directly back to absolute pixels (0 to 273px bar scale)
        local percentage = (inputVal - min) / (max - min)
        if max == min then percentage = 0 end -- Division-by-zero protection fallback
        
        SliderTrail.Size = UDim2.new(0, math.clamp(percentage * 273, 0, 273), 0, 7)
        
        -- Fire output callback immediately
        callback(SliderNumber.Text)
    end)
end

